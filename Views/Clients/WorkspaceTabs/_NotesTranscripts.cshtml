@model ClientWorkspaceViewModel
@{
    var client = Model.Client;
}

<div class="row g-3">
    <div class="col-lg-6">
        <h3 class="panel-title">Add note</h3>
        <form asp-controller="Notes" asp-action="Create" method="post" class="form-grid">
            <input type="hidden" name="clientId" value="@client.Id" />
            <input name="NoteTitle" class="form-control" placeholder="Title" />
            <select name="NoteType" asp-items="Html.GetEnumSelectList<NoteType>()" class="form-select"></select>
            <input name="CreatedBy" class="form-control" placeholder="Created by" />
            <textarea name="NoteText" class="form-control compact-textarea form-grid-wide" placeholder="Note"></textarea>
            <button class="btn btn-primary" type="submit">Add Note</button>
        </form>
        <div class="panel-header mt-4">
            <h3 class="panel-title">Notes</h3>
            <span class="status-badge status-info">@Model.NoteCount total</span>
        </div>
        @if (client.Notes.Any())
        {
            @foreach (var note in client.Notes.OrderByDescending(item => item.CreatedAt))
            {
                <div class="mb-3">
                    <div class="fw-semibold">@note.NoteTitle <span class="status-badge status-neutral">@note.NoteType.ToDisplayName()</span></div>
                    <div class="preline">@note.NoteText</div>
                    <div class="table-note">@note.CreatedAt.ToString("yyyy-MM-dd HH:mm") · @note.CreatedBy</div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <strong>No consultant notes yet.</strong>
                Add discovery notes, decisions, assumptions, or follow-ups.
            </div>
        }
    </div>
    <div class="col-lg-6">
        <h3 class="panel-title">Add transcript</h3>
        <form asp-controller="Notes" asp-action="Transcript" method="post" class="form-grid">
            <input type="hidden" name="clientId" value="@client.Id" />
            <input name="SessionTitle" class="form-control" placeholder="Session title" />
            <input name="SessionDate" type="date" class="form-control" />
            <textarea name="TranscriptText" class="form-control compact-textarea form-grid-wide" placeholder="Transcript"></textarea>
            <textarea name="Summary" class="form-control compact-textarea form-grid-wide" placeholder="Summary"></textarea>
            <textarea name="KeyDecisions" class="form-control compact-textarea" placeholder="Key decisions"></textarea>
            <textarea name="FollowUpQuestions" class="form-control compact-textarea" placeholder="Follow-up questions"></textarea>
            <button class="btn btn-primary" type="submit">Add Transcript</button>
        </form>
        <div class="panel-header mt-4">
            <h3 class="panel-title">Transcripts</h3>
            <span class="status-badge status-info">@Model.TranscriptCount total</span>
        </div>
        @if (client.MeetingTranscripts.Any())
        {
            @foreach (var transcript in client.MeetingTranscripts.OrderByDescending(item => item.SessionDate))
            {
                <div class="mb-3">
                    <div class="fw-semibold">@transcript.SessionTitle</div>
                    <div class="table-note">@transcript.SessionDate.ToString("yyyy-MM-dd")</div>
                    <div class="preline">@transcript.Summary</div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <strong>No transcripts captured yet.</strong>
                Paste a session transcript after a consultant call.
            </div>
        }
    </div>
</div>
