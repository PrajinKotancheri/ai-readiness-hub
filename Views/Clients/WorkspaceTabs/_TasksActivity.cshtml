@model ClientWorkspaceViewModel
@{
    var client = Model.Client;
}

<section class="panel mb-3">
    <div class="panel-header">
        <h3 class="panel-title">Tasks / follow-ups</h3>
        <span class="status-badge status-info" data-workspace-count="openTaskCount">@Model.OpenTaskCount open</span>
    </div>
    <form asp-controller="Tasks" asp-action="Create" method="post" class="form-grid mb-3">
        <input type="hidden" name="clientId" value="@client.Id" />
        <input name="TaskTitle" class="form-control" placeholder="Task title" />
        <select name="TaskType" asp-items="Html.GetEnumSelectList<TaskType>()" class="form-select"></select>
        <input name="AssignedTo" class="form-control" placeholder="Assigned to" />
        <input name="DueDate" type="date" class="form-control" />
        <select name="Priority" asp-items="Html.GetEnumSelectList<TaskPriority>()" class="form-select"></select>
        <textarea name="TaskDescription" class="form-control compact-textarea form-grid-wide" placeholder="Description"></textarea>
        <button class="btn btn-primary" type="submit">Add Follow-up Task</button>
    </form>
    @if (client.Tasks.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead><tr><th>Task</th><th>Type</th><th>Due</th><th>Priority</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var task in client.Tasks.OrderBy(item => item.DueDate ?? DateTime.MaxValue))
                    {
                        <tr>
                            <td><div class="fw-semibold">@task.TaskTitle</div><div class="table-note">@task.TaskDescription</div></td>
                            <td>@task.TaskType.ToDisplayName()</td>
                            <td class="@(task.DueDate.HasValue && task.DueDate.Value.Date < DateTime.UtcNow.Date && task.Status != ClientTaskStatus.Done ? "overdue" : null)">@(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td><span class="status-badge @task.Priority.ToBadgeClass()">@task.Priority.ToDisplayName()</span></td>
                            <td><span class="status-badge @task.Status.ToBadgeClass()">@task.Status.ToDisplayName()</span></td>
                            <td>
                                <form asp-controller="Tasks" asp-action="Complete" method="post">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <button class="btn btn-outline-primary btn-sm" type="submit">Complete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <strong>No follow-up tasks yet.</strong>
            Add the next consultant action, client reminder, or review checkpoint.
        </div>
    }
</section>

<section class="panel">
    <div class="panel-header">
        <h3 class="panel-title">Recent activity</h3>
        <span class="status-badge status-info" data-workspace-count="activityLogCount">@Model.ActivityLogCount total</span>
    </div>
    @if (client.ActivityLogs.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm">
                <thead><tr><th>Time</th><th>Type</th><th>Description</th><th>By</th></tr></thead>
                <tbody>
                    @foreach (var activity in client.ActivityLogs.OrderByDescending(item => item.CreatedAt))
                    {
                        <tr>
                            <td>@Html.LocalDateTime(activity.CreatedAt, "datetime")</td>
                            <td>@activity.ActivityType</td>
                            <td>@activity.Description</td>
                            <td>@activity.CreatedBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <strong>No activity logged yet.</strong>
            Client updates, generated drafts, and consultant actions will appear here.
        </div>
    }
</section>
