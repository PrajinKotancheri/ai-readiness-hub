@model ClientCompany
@{
    ViewData["Title"] = "Edit client";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit client</h1>
        <p class="page-subtitle">@Model.CompanyName</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Workspace" asp-route-id="@Model.Id">Workspace</a>
</div>

<section class="panel">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <input type="hidden" asp-for="Id" />
        <partial name="_ClientForm" model="Model" />
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
