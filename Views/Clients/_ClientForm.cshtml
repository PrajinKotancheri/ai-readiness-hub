@model ClientCompany

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-grid">
    <div>
        <label asp-for="CompanyName" class="form-label">Company name</label>
        <input asp-for="CompanyName" class="form-control" />
        <span asp-validation-for="CompanyName" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Industry" class="form-label"></label>
        <input asp-for="Industry" class="form-control" />
    </div>
    <div>
        <label asp-for="WebsiteUrl" class="form-label">Website</label>
        <input asp-for="WebsiteUrl" class="form-control" />
    </div>
    <div>
        <label asp-for="Country" class="form-label"></label>
        <input asp-for="Country" class="form-control" />
    </div>
    <div>
        <label asp-for="Region" class="form-label"></label>
        <input asp-for="Region" class="form-control" />
    </div>
    <div>
        <label asp-for="CompanySizeRange" class="form-label">Company size</label>
        <input asp-for="CompanySizeRange" class="form-control" />
    </div>
    <div>
        <label asp-for="RevenueRange" class="form-label">Revenue range</label>
        <input asp-for="RevenueRange" class="form-control" />
    </div>
    <div>
        <label asp-for="BusinessModel" class="form-label">Business model</label>
        <input asp-for="BusinessModel" class="form-control" />
    </div>
    <div>
        <label asp-for="ContactPersonName" class="form-label">Contact person</label>
        <input asp-for="ContactPersonName" class="form-control" />
    </div>
    <div>
        <label asp-for="ContactPersonEmail" class="form-label">Contact email</label>
        <input asp-for="ContactPersonEmail" class="form-control" />
    </div>
    <div>
        <label asp-for="ContactPersonPhone" class="form-label">Contact phone</label>
        <input asp-for="ContactPersonPhone" class="form-control" />
    </div>
    <div>
        <label asp-for="ConsultingPackage" class="form-label">Consulting package</label>
        <input asp-for="ConsultingPackage" class="form-control" />
    </div>
    <div>
        <label asp-for="AssignedConsultant" class="form-label">Assigned consultant</label>
        <input asp-for="AssignedConsultant" class="form-control" />
    </div>
    <div>
        <label asp-for="Priority" class="form-label"></label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<TaskPriority>()" class="form-select"></select>
    </div>
    <div>
        <label asp-for="CurrentStage" class="form-label">Current stage</label>
        <select asp-for="CurrentStage" asp-items="Html.GetEnumSelectList<ClientStage>()" class="form-select"></select>
    </div>
    <div>
        <label asp-for="OverallReadinessScore" class="form-label">Readiness score</label>
        <input asp-for="OverallReadinessScore" class="form-control" />
    </div>
    <div class="form-grid-wide">
        <label asp-for="KeyRisksSummary" class="form-label">Key risks summary</label>
        <textarea asp-for="KeyRisksSummary" class="form-control compact-textarea"></textarea>
    </div>
    <div class="form-grid-wide">
        <label asp-for="NextAction" class="form-label">Next action</label>
        <input asp-for="NextAction" class="form-control" />
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <button type="submit" class="btn btn-primary">Save client</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</div>
