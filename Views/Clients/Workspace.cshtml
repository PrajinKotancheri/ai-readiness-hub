@model ClientWorkspaceViewModel
@{
    ViewData["Title"] = $"{Model.Client.CompanyName} workspace";
    var client = Model.Client;
    var assessment = Model.LatestAssessment;
    var formSettings = Model.ReadinessFormSettings;
    var latestReportStatus = Model.LatestReport?.ReportStatus ?? ReportStatus.NotStarted;
    var responses = Model.AssessmentResponses;
    var selectedResponse = Model.SelectedAssessmentResponse;
    var latestResponse = responses
        .Where(response => response.Status != AssessmentResponseStatus.Ignored)
        .OrderByDescending(response => response.ReceivedAt)
        .ThenByDescending(response => response.ResponseNumber)
        .FirstOrDefault();
    var selectedMissingAnswers = selectedResponse?.Answers.Count(answer => string.IsNullOrWhiteSpace(answer.AnswerText) || answer.CompletenessStatus == CompletenessStatus.Missing) ?? 0;
}

<section class="workspace-summary-card">
    <div>
        <div class="page-kicker">Client workspace</div>
        <h1 class="workspace-title">@client.CompanyName</h1>
        <p class="workspace-meta">@client.Industry · @client.Country @client.Region</p>
        <div class="workspace-facts">
            <div>
                <div class="field-label">Website</div>
                @if (!string.IsNullOrWhiteSpace(client.WebsiteUrl))
                {
                    <a href="@client.WebsiteUrl" target="_blank" rel="noreferrer">@client.WebsiteUrl</a>
                }
                else
                {
                    <span>Not set</span>
                }
            </div>
            <div>
                <div class="field-label">Contact person</div>
                <div>@client.ContactPersonName</div>
                <div class="table-note">@client.ContactPersonEmail</div>
            </div>
            <div>
                <div class="field-label">Assigned consultant</div>
                <div>@client.AssignedConsultant</div>
            </div>
            <div>
                <div class="field-label">Package</div>
                <div>@(client.ConsultingPackage ?? "Not set")</div>
            </div>
        </div>
    </div>
    <div class="summary-stat-grid">
        <div class="summary-stat">
            <div class="field-label">Current stage</div>
            <span class="status-badge @client.CurrentStage.ToBadgeClass()">@client.CurrentStage.ToDisplayName()</span>
        </div>
        <div class="summary-stat">
            <div class="field-label">Report status</div>
            <span class="status-badge @latestReportStatus.ToBadgeClass()">@latestReportStatus.ToDisplayName()</span>
        </div>
        <div class="summary-stat">
            <div class="field-label">Priority</div>
            <span class="status-badge @client.Priority.ToBadgeClass()">@client.Priority.ToDisplayName()</span>
        </div>
        <div class="summary-stat">
            <div class="field-label">Readiness score</div>
            <div class="score-number">@(Model.LatestScore?.OverallScore.ToString() ?? client.OverallReadinessScore?.ToString("0.##") ?? "-")</div>
        </div>
    </div>
    <div>
        <div class="next-action-card">
            <div class="field-label">Next action</div>
            <div class="next-action-text">@(!string.IsNullOrWhiteSpace(client.NextAction) ? client.NextAction : "Define the next consultant action.")</div>
            <div class="field-label">Key risks summary</div>
            <p class="mb-3">@(!string.IsNullOrWhiteSpace(client.KeyRisksSummary) ? client.KeyRisksSummary : "No risk summary captured yet.")</p>
            <div class="action-strip">
                <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@client.Id">Edit client</a>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">All clients</a>
            </div>
        </div>
    </div>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="panel">
    <div class="panel-header">
        <h2 class="panel-title">Workflow timeline</h2>
        <span class="table-note">Scroll horizontally to scan the full process.</span>
    </div>
    <div class="timeline-wrap">
    <div class="timeline">
        @foreach (var step in client.WorkflowSteps.OrderBy(step => step.DisplayOrder))
        {
            var timelineClass = step.Status switch
            {
                WorkflowStepStatus.Completed => "timeline-completed",
                WorkflowStepStatus.InProgress => "timeline-current",
                WorkflowStepStatus.Blocked => "timeline-blocked",
                _ => "timeline-notstarted"
            };
            <div class="timeline-step @timelineClass">
                <div class="timeline-node">@step.DisplayOrder</div>
                <div class="timeline-card">
                    <div class="timeline-label">@step.StageName</div>
                    <span class="status-badge @step.Status.ToBadgeClass()">@step.Status.ToDisplayName()</span>
                    <div class="table-note mt-2">@(step.CompletedAt?.ToString("yyyy-MM-dd") ?? "No completion date")</div>
                </div>
            </div>
        }
    </div>
    </div>
</section>

<section class="panel tabs-shell">
    <ul class="nav nav-tabs workflow-tabs" id="workspaceTabs" role="tablist">
        <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#overview" type="button">Overview</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#assessment" type="button">Assessment Answers</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#documents" type="button">Documents</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#notes" type="button">Notes & Transcripts</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#analysis" type="button">AI Drafts</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#gap" type="button">Gap Analysis</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#swot" type="button">SWOT</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#insights" type="button">Industry & Competitors</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#usecases" type="button">Use Cases & Scoring</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#roadmap" type="button">Roadmap</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#reports" type="button">Reports</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tasks" type="button">Tasks / Follow-ups</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#activity" type="button">Activity Log</button></li>
    </ul>

    <div class="tab-content pt-3">
        <div class="tab-pane fade show active" id="overview">
            <form asp-controller="Analysis" asp-action="Generate" method="post" class="action-groups">
                <input type="hidden" name="clientId" value="@client.Id" />
                <div class="action-group">
                    <div class="action-group-title">Intake</div>
                    <div class="action-strip">
                        <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="tab" data-bs-target="#assessment">Manual Import / Fallback</button>
                        <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="tab" data-bs-target="#documents">Upload Document</button>
                        <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="tab" data-bs-target="#notes">Add Note</button>
                    </div>
                </div>
                <div class="action-group">
                    <div class="action-group-title">Analysis</div>
                    <div class="action-strip">
                        <button class="btn btn-primary btn-sm" name="operation" value="company-summary">Company Summary</button>
                        <button class="btn btn-primary btn-sm" name="operation" value="gap-analysis">Gap Analysis</button>
                        <button class="btn btn-primary btn-sm" name="operation" value="swot">SWOT</button>
                        <button class="btn btn-primary btn-sm" name="operation" value="use-cases">Use Cases</button>
                        <button class="btn btn-primary btn-sm" name="operation" value="readiness-score">Score</button>
                        <button class="btn btn-primary btn-sm" name="operation" value="roadmap">Roadmap</button>
                    </div>
                </div>
                <div class="action-group">
                    <div class="action-group-title">Report</div>
                    <button class="btn btn-primary btn-sm" name="operation" value="report">Generate Report Draft</button>
                </div>
            </form>
            <div class="metric-grid">
                <div class="metric-card"><div class="metric-label">Assessment responses</div><div class="metric-value">@Model.AssessmentResponseCount</div></div>
                <div class="metric-card"><div class="metric-label">Documents</div><div class="metric-value">@Model.DocumentCount</div></div>
                <div class="metric-card"><div class="metric-label">Open gaps</div><div class="metric-value">@Model.OpenGapCount</div></div>
                <div class="metric-card"><div class="metric-label">AI use cases</div><div class="metric-value">@Model.UseCaseCount</div></div>
            </div>
        </div>

        <div class="tab-pane fade" id="assessment">
            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="panel">
                        <div class="panel-header">
                            <h3 class="panel-title">Google Form delivery</h3>
                            <span class="status-badge @((assessment?.FormStatus ?? ReadinessFormStatus.NotSent).ToBadgeClass())">@((assessment?.FormStatus ?? ReadinessFormStatus.NotSent).ToDisplayName())</span>
                        </div>

                        <div class="detail-grid mb-3">
                            <div>
                                <div class="field-label">Default form URL</div>
                                <div class="text-break">@(formSettings?.DefaultFormUrl ?? "Not configured")</div>
                            </div>
                            <div>
                                <div class="field-label">Custom form URL</div>
                                <div class="text-break">@(assessment?.CustomFormUrl ?? "Using default")</div>
                            </div>
                            <div>
                                <div class="field-label">Client token</div>
                                <code>@(assessment?.ClientToken ?? "Not generated")</code>
                            </div>
                            <div>
                                <div class="field-label">Sent to email</div>
                                <div>@(assessment?.SentToEmail ?? client.ContactPersonEmail ?? "No client email")</div>
                            </div>
                            <div>
                                <div class="field-label">Sent date</div>
                                <div>@(assessment?.SentAt?.ToString("yyyy-MM-dd HH:mm") ?? "Not sent")</div>
                            </div>
                            <div>
                                <div class="field-label">Last reminder</div>
                                <div>@(assessment?.LastReminderSentAt?.ToString("yyyy-MM-dd HH:mm") ?? "No reminder sent")</div>
                            </div>
                            <div>
                                <div class="field-label">Response received</div>
                                <div>@(latestResponse?.ReceivedAt.ToString("yyyy-MM-dd HH:mm") ?? "Not received")</div>
                            </div>
                            <div>
                                <div class="field-label">Latest answers</div>
                                <div>@(latestResponse?.AnswerCount.ToString() ?? "0")</div>
                            </div>
                        </div>

                        <label class="form-label">Generated unique form URL</label>
                        <div class="copy-field mb-3">
                            <textarea id="generatedFormUrl" class="form-control" rows="4" readonly>@assessment?.GeneratedFormUrl</textarea>
                            <button class="btn btn-outline-secondary btn-sm" type="button" data-copy-target="generatedFormUrl">Copy form link</button>
                        </div>

                        @if (formSettings is null || string.IsNullOrWhiteSpace(formSettings.DefaultFormUrl) || string.IsNullOrWhiteSpace(formSettings.ClientReferenceEntryId))
                        {
                            <div class="empty-state mb-3">
                                <strong>Google Form settings are incomplete.</strong>
                                Add the default form URL and Client Reference Entry ID before sending forms.
                                <div class="mt-2"><a asp-controller="Settings" asp-action="ReadinessForm">Open readiness form settings</a></div>
                            </div>
                        }

                        <div class="action-strip mb-3">
                            <form asp-controller="Assessments" asp-action="GenerateLink" method="post">
                                <input type="hidden" name="clientId" value="@client.Id" />
                                <button class="btn btn-outline-primary btn-sm" type="submit">Generate unique form link</button>
                            </form>
                            <form asp-controller="Assessments" asp-action="SendReadinessForm" method="post">
                                <input type="hidden" name="clientId" value="@client.Id" />
                                <button class="btn btn-primary btn-sm" type="submit">Send readiness form</button>
                            </form>
                            <form asp-controller="Assessments" asp-action="SendReminder" method="post">
                                <input type="hidden" name="clientId" value="@client.Id" />
                                <button class="btn btn-outline-primary btn-sm" type="submit">Send reminder</button>
                            </form>
                        </div>

                        <form asp-controller="Assessments" asp-action="UpdateCustomFormLink" method="post" class="mb-3">
                            <input type="hidden" name="clientId" value="@client.Id" />
                            <label class="form-label">Client-specific form override</label>
                            <div class="input-group">
                                <input name="customFormUrl" value="@assessment?.CustomFormUrl" class="form-control" placeholder="Optional custom Google Form URL" />
                                <button class="btn btn-outline-primary" type="submit">Edit custom form link</button>
                            </div>
                        </form>
                    </div>

                    <form asp-controller="Assessments" asp-action="Import" method="post" class="panel">
                        <input type="hidden" name="clientId" value="@client.Id" />
                        <h3 class="panel-title">Manual Import / Fallback</h3>
                        <label class="form-label">Paste JSON or text answers</label>
                        <textarea name="rawResponseText" class="form-control" rows="8" placeholder="Section | Question | Answer"></textarea>
                        <button class="btn btn-primary mt-2" type="submit">Import assessment answers</button>
                    </form>
                </div>
                <div class="col-lg-8">
                    <div class="metric-grid mb-3 response-summary-grid">
                        <div class="metric-card">
                            <div class="metric-label">Total responses</div>
                            <div class="metric-value">@Model.AssessmentResponseCount</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Latest received</div>
                            <div class="metric-value response-date-value">@(latestResponse?.ReceivedAt.ToString("dd MMM") ?? "-")</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Latest answer count</div>
                            <div class="metric-value">@(latestResponse?.AnswerCount.ToString() ?? "0")</div>
                        </div>
                        <div class="metric-card">
                            <div class="metric-label">Missing in selected</div>
                            <div class="metric-value">@selectedMissingAnswers</div>
                        </div>
                    </div>

                    <section class="panel">
                        <div class="panel-header">
                            <h3 class="panel-title">Assessment responses</h3>
                            <span class="status-badge status-info">@Model.AssessmentResponseCount total</span>
                        </div>
                        @if (responses.Any())
                        {
                            <div class="table-responsive">
                                <table class="table response-table">
                                    <thead>
                                        <tr>
                                            <th>Response</th>
                                            <th>Source</th>
                                            <th>Submitted</th>
                                            <th>Received</th>
                                            <th>Answers</th>
                                            <th>Status</th>
                                            <th>External ID</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var response in responses.OrderByDescending(item => item.ResponseNumber))
                                        {
                                            var isLatest = latestResponse?.Id == response.Id;
                                            var isSelected = selectedResponse?.Id == response.Id;
                                            <tr class="@(isSelected ? "selected-response-row" : null)">
                                                <td>
                                                    <div class="fw-semibold">@response.ResponseLabel</div>
                                                    @if (isLatest)
                                                    {
                                                        <span class="status-badge status-good">Latest</span>
                                                    }
                                                </td>
                                                <td><span class="status-badge status-info">@response.Source.ToDisplayName()</span></td>
                                                <td>@(response.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                                <td>@response.ReceivedAt.ToString("dd MMM yyyy HH:mm")</td>
                                                <td>@response.AnswerCount</td>
                                                <td><span class="status-badge @response.Status.ToBadgeClass()">@response.Status.ToDisplayName()</span></td>
                                                <td class="text-break">@(response.ExternalResponseId ?? "-")</td>
                                                <td>
                                                    <a class="btn @(isSelected ? "btn-primary" : "btn-outline-primary") btn-sm" asp-controller="Clients" asp-action="Workspace" asp-route-id="@client.Id" asp-route-responseId="@response.Id">View details</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <strong>No assessment responses yet.</strong>
                                Responses will appear here after Google Form submission or manual import.
                            </div>
                        }
                    </section>

                    <section class="panel">
                        @if (selectedResponse is not null)
                        {
                            <div class="panel-header">
                                <div>
                                    <h3 class="panel-title">@selectedResponse.ResponseLabel details</h3>
                                    <div class="table-note">@selectedResponse.Source.ToDisplayName() · @selectedResponse.AnswerCount answers</div>
                                </div>
                                <div class="action-strip">
                                    @if (latestResponse?.Id == selectedResponse.Id)
                                    {
                                        <span class="status-badge status-good">Latest</span>
                                    }
                                    <span class="status-badge @selectedResponse.Status.ToBadgeClass()">@selectedResponse.Status.ToDisplayName()</span>
                                </div>
                            </div>
                            <div class="detail-grid response-detail-grid mb-3">
                                <div>
                                    <div class="field-label">Source</div>
                                    <div>@selectedResponse.Source.ToDisplayName()</div>
                                </div>
                                <div>
                                    <div class="field-label">Submitted at</div>
                                    <div>@(selectedResponse.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "Not provided")</div>
                                </div>
                                <div>
                                    <div class="field-label">Received at</div>
                                    <div>@selectedResponse.ReceivedAt.ToString("dd MMM yyyy HH:mm")</div>
                                </div>
                                <div>
                                    <div class="field-label">External response ID</div>
                                    <div class="text-break">@(selectedResponse.ExternalResponseId ?? "Not available")</div>
                                </div>
                                <div>
                                    <div class="field-label">Client token</div>
                                    <code>@(selectedResponse.ClientToken ?? assessment?.ClientToken ?? "Not generated")</code>
                                </div>
                                <div>
                                    <div class="field-label">Answer count</div>
                                    <div>@selectedResponse.AnswerCount</div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <input class="form-control" id="answerFilter" type="search" placeholder="Filter answers" />
                            </div>

                            @if (Model.SelectedAnswersBySection.Any())
                            {
                                @foreach (var answerGroup in Model.SelectedAnswersBySection)
                                {
                                    <div class="answer-section">
                                        <h4 class="answer-section-title">@answerGroup.Key</h4>
                                        <div class="answer-card-grid">
                                            @foreach (var answer in answerGroup)
                                            {
                                                <article class="answer-card" data-answer-search="@($"{answerGroup.Key} {answer.QuestionText} {answer.AnswerText}")">
                                                    <div class="answer-card-header">
                                                        <div class="answer-question">@answer.QuestionText</div>
                                                        <span class="status-badge @answer.CompletenessStatus.ToBadgeClass()">@answer.CompletenessStatus.ToDisplayName()</span>
                                                    </div>
                                                    <div class="answer-text">@(!string.IsNullOrWhiteSpace(answer.AnswerText) ? answer.AnswerText : "No answer provided")</div>
                                                </article>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-state">
                                    <strong>No answers in this response.</strong>
                                    The response was recorded, but no answer rows were included.
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <strong>Select a response to view answers.</strong>
                                Response details will show only the answers from the selected submission.
                            </div>
                        }
                    </section>

                    <form asp-controller="Assessments" asp-action="AddAnswer" method="post" class="form-grid panel">
                        <h3 class="panel-title form-grid-wide">Add one manual response</h3>
                        <input type="hidden" name="clientId" value="@client.Id" />
                        <input name="sectionName" class="form-control" placeholder="Section" />
                        <input name="questionText" class="form-control" placeholder="Question" />
                        <input name="answerType" class="form-control" placeholder="Answer type" />
                        <label class="form-check align-self-center"><input name="isMandatory" value="true" class="form-check-input" type="checkbox" /> Mandatory</label>
                        <textarea name="answerText" class="form-control compact-textarea form-grid-wide" placeholder="Answer"></textarea>
                        <button class="btn btn-outline-primary" type="submit">Add manual answer</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="documents">
            <div class="row g-3">
                <div class="col-lg-5">
                    <h3 class="panel-title">Upload or register document</h3>
                    <form asp-controller="Documents" asp-action="Create" method="post" enctype="multipart/form-data" class="form-grid">
                        <input type="hidden" name="clientId" value="@client.Id" />
                        <input name="FileName" class="form-control" placeholder="File name" />
                        <input name="upload" type="file" class="form-control" />
                        <select name="DocumentType" asp-items="Html.GetEnumSelectList<DocumentType>()" class="form-select"></select>
                        <input name="UploadedBy" class="form-control" placeholder="Uploaded by" />
                        <textarea name="Description" class="form-control compact-textarea form-grid-wide" placeholder="Description"></textarea>
                        <textarea name="AiSummary" class="form-control compact-textarea form-grid-wide" placeholder="AI summary or leave blank for placeholder"></textarea>
                        <textarea name="KeyInsights" class="form-control compact-textarea form-grid-wide" placeholder="Key insights"></textarea>
                        <button class="btn btn-primary" type="submit">Upload Document</button>
                    </form>
                </div>
                <div class="col-lg-7">
                    <h3 class="panel-title">Client documents</h3>
                    @if (client.Documents.Any())
                    {
                        @foreach (var document in client.Documents.OrderByDescending(item => item.UploadedAt))
                        {
                            <div class="panel">
                                <div class="d-flex justify-content-between gap-2">
                                    <div>
                                        <div class="fw-semibold">@document.FileName</div>
                                        <div class="table-note">@document.DocumentType.ToDisplayName() · @document.UploadedAt.ToString("yyyy-MM-dd")</div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(document.FilePath))
                                    {
                                        <a class="btn btn-outline-secondary btn-sm" href="@document.FilePath" target="_blank">Open</a>
                                    }
                                </div>
                                <form asp-controller="Documents" asp-action="UpdateInsights" method="post" class="mt-2">
                                    <input type="hidden" name="id" value="@document.Id" />
                                    <label class="form-label">Summary</label>
                                    <textarea name="aiSummary" class="form-control compact-textarea">@document.AiSummary</textarea>
                                    <label class="form-label mt-2">Key insights</label>
                                    <textarea name="keyInsights" class="form-control compact-textarea">@document.KeyInsights</textarea>
                                    <input type="hidden" name="usedInReport" value="false" />
                                    <label class="form-check mt-2">
                                        @if (document.UsedInReport)
                                        {
                                            <input name="usedInReport" value="true" class="form-check-input" type="checkbox" checked />
                                        }
                                        else
                                        {
                                            <input name="usedInReport" value="true" class="form-check-input" type="checkbox" />
                                        }
                                        Used in report
                                    </label>
                                    <button class="btn btn-outline-primary btn-sm mt-2" type="submit">Save insights</button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <strong>No documents uploaded yet.</strong>
                            Upload or register client documents so summaries and report evidence can be captured.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="notes">
            <div class="row g-3">
                <div class="col-lg-6">
                    <h3 class="panel-title">Add note</h3>
                    <form asp-controller="Notes" asp-action="Create" method="post" class="form-grid">
                        <input type="hidden" name="clientId" value="@client.Id" />
                        <input name="NoteTitle" class="form-control" placeholder="Title" />
                        <select name="NoteType" asp-items="Html.GetEnumSelectList<NoteType>()" class="form-select"></select>
                        <input name="CreatedBy" class="form-control" placeholder="Created by" />
