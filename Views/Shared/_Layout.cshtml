@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var dashboardActive = currentController.Equals("Dashboard", StringComparison.OrdinalIgnoreCase);
    var clientsActive = currentController.Equals("Clients", StringComparison.OrdinalIgnoreCase) ||
        new[] { "Assessments", "Documents", "Notes", "Analysis", "GapAnalysis", "Swot", "Insights", "UseCases", "Roadmap", "Reports", "Tasks" }
            .Contains(currentController, StringComparer.OrdinalIgnoreCase);
    var settingsActive = currentController.Equals("Settings", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Readiness Consultant Hub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AI_Readiness_Hub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold app-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <span class="brand-mark">AI</span>
                    <span>AI Readiness Consultant Hub</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link @(dashboardActive ? "active" : null)" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link @(clientsActive ? "active" : null)" asp-area="" asp-controller="Clients" asp-action="Index">Clients</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link @(settingsActive ? "active" : null)" asp-area="" asp-controller="Settings" asp-action="ReadinessForm">Settings</a>
                        </li>
                    </ul>
                    <a class="btn btn-primary btn-sm nav-action" asp-controller="Clients" asp-action="Create">New client</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid app-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted small">
        <div class="container-fluid">
            &copy; 2026 - AI Readiness Consultant Hub
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
